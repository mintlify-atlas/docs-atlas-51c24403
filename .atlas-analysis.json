  "keyFeatures": [
    "PostgreSQL-compatible distributed SQL",
    "Multi-region deployments with xCluster replication",
    "Distributed ACID transactions with Spanner-inspired architecture",
    "Horizontal scalability with automatic sharding",
    "High availability with Raft consensus",
    "Multi-API support (YSQL and YCQL)",
    "Change Data Capture (CDC)",
    "Vector search with pgvector extension",
    "Read replicas and follower reads",
    "Encryption at rest and in transit"
  ],
